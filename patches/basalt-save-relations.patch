+  void saveRelations() {
+    std::ofstream os(relations_name);
+
+    os << "#timestamp [ns],p_RS_R_x [m],p_RS_R_y [m],p_RS_R_z [m],q_RS_w [],q_RS_x "
+          "[],q_RS_y [],q_RS_z [],v_RS_R_x [m s^-1],v_RS_R_y [m s^-1],v_RS_R_z [m "
+          "s^-1],w_RS_R_x [rad s^-1],w_RS_R_y [rad s^-1],w_RS_R_z [rad s^-1]"
+       << std::endl;
+
+    for (size_t i = 0; i < vio_t_ns.size(); i++) {
+      const Sophus::SE3d& pose = vio_T_w_i[i];
+      const Eigen::Vector3d& vel = vio_vel_w_i[i];
+
+      Eigen::Vector3d ang_vel = Eigen::Vector3d::Zero();
+      if (i > 0) {
+        double dt = (vio_t_ns[i] - vio_t_ns[i - 1]) * 1e-9;
+        if (dt > 0) {
+          Sophus::SO3d inc = pose.so3() * vio_T_w_i[i - 1].so3().inverse();
+          ang_vel = inc.log() / dt;
+        }
+      }
+
+      os << std::fixed << std::setprecision(10) << vio_t_ns[i] << "," << pose.translation().x() << ","
+         << pose.translation().y() << "," << pose.translation().z() << "," << pose.unit_quaternion().w() << ","
+         << pose.unit_quaternion().x() << "," << pose.unit_quaternion().y() << "," << pose.unit_quaternion().z() << ","
+         << vel.x() << "," << vel.y() << "," << vel.z() << "," << ang_vel.x() << "," << ang_vel.y() << ","
+         << ang_vel.z() << std::endl;
+    }
+
+    std::cout << "Saved SLAM relations (pose + velocity) in " << relations_name << std::endl;
+  }
